# ─────────────────────────────────────────────────────────────
# fanvault-commerce-service — Environment Configuration
# Copy this file to .env and fill in all required values.
# Never commit the actual .env file to source control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
# Purpose  : Express listening port
# Required : Yes
PORT=3002

# Purpose  : Node.js runtime context
# Required : Yes
NODE_ENV=production

# ── AWS ───────────────────────────────────────────────────────
# Purpose  : AWS region where DynamoDB tables and S3 bucket are deployed
# Required : Yes
AWS_REGION=us-east-1

# ── DynamoDB Tables ───────────────────────────────────────────
# Purpose  : Name of the DynamoDB table for products
# Required : Yes
DYNAMODB_TABLE_PRODUCTS=fanvault-products

# Purpose  : Name of the DynamoDB table for orders
# Required : Yes
DYNAMODB_TABLE_ORDERS=fanvault-orders

# ── JWT ───────────────────────────────────────────────────────
# Purpose  : Secret key used to VERIFY incoming access tokens
#            Must match the JWT_SECRET in fanvault-user-auth-service exactly
# Required : Yes
# Secret   : YES
JWT_SECRET=CHANGE_ME_MIN_32_CHARS

# ── S3 Image Proxy ────────────────────────────────────────────
# Purpose  : SSM Parameter Store paths for S3 bucket config
#            Resolved at runtime — not hardcoded here
# Required : Yes (in production with S3 product images)
SSM_S3_BUCKET_PATH=/fanvault/s3/bucket
SSM_S3_REGION_PATH=/fanvault/s3/region

# ── CORS ──────────────────────────────────────────────────────
# Purpose  : Allowed client origins
# Required : Yes
CORS_ORIGIN=https://fanvault.example.com

# ── AWS Secrets Manager (optional, production) ────────────────
# Purpose  : If true, JWT_SECRET is fetched from Secrets Manager at startup
# Required : No
USE_SECRETS_MANAGER=false
SECRET_ID=production/fanvault-auth
