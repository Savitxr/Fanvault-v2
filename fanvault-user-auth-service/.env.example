# ─────────────────────────────────────────────────────────────
# fanvault-user-auth-service — Environment Configuration
# Copy this file to .env and fill in all required values.
# Never commit the actual .env file to source control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
# Purpose  : Express listening port
# Required : Yes
PORT=3001

# Purpose  : Node.js runtime context
# Required : Yes
NODE_ENV=production

# ── AWS ───────────────────────────────────────────────────────
# Purpose  : AWS region where DynamoDB tables and Secrets Manager are deployed
# Required : Yes
AWS_REGION=us-east-1

# ── DynamoDB Tables ───────────────────────────────────────────
# Purpose  : Name of the DynamoDB table for auth users
# Required : Yes
DYNAMODB_TABLE_USERS=fanvault-users

# Purpose  : Name of the DynamoDB table for user profiles
# Required : Yes
DYNAMODB_TABLE_PROFILES=fanvault-profiles

# ── JWT ───────────────────────────────────────────────────────
# Purpose  : Signing secret for short-lived access tokens (shared with Commerce Service)
# Required : Yes
# Secret   : YES — minimum 32 random bytes
JWT_SECRET=CHANGE_ME_MIN_32_CHARS

# Purpose  : Expiry duration of access tokens
# Required : No (defaults to 15m)
JWT_EXPIRES_IN=15m

# Purpose  : Signing secret for long-lived refresh tokens (kept only in this service)
# Required : Yes
# Secret   : YES — different value from JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_FROM_JWT_SECRET

# Purpose  : Expiry duration of refresh tokens
# Required : No (defaults to 7d)
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
# Purpose  : Allowed client origins
# Required : Yes
CORS_ORIGIN=https://fanvault.example.com

# ── AWS Secrets Manager (optional, production) ────────────────
# Purpose  : If true, JWT_SECRET and JWT_REFRESH_SECRET are fetched from
#            AWS Secrets Manager at startup instead of .env
# Required : No (set true in production)
USE_SECRETS_MANAGER=false
SECRET_ID=production/fanvault-auth
